---
import "@/style/global.css"

interface Endpoint {
  method: string
  path: string
  description: string
  request?: string
  response: string
}

const endpoints: Endpoint[] = [
  {
    method: "GET",
    path: "/api/domain",
    description: "List available mailbox domains.",
    response: `["example.com", "example.org"]`,
  },
  {
    method: "GET",
    path: "/api/fetch?to={address}&limit={limit}&offset={offset}",
    description:
      "Paginated list of received emails for a mailbox address. `limit` defaults to 50, max 200. `offset` defaults to 0.",
    request: `GET /api/fetch?to=foo@example.com&limit=50&offset=0`,
    response: `[
  {
    "id": 123,
    "to": "foo@example.com",
    "from": "sender@example.org",
    "subject": "Hello",
    "created_at": "2026-07-13T10:00:00Z"
  }
]`,
  },
  {
    method: "GET",
    path: "/api/fetch/{id}",
    description: "Full detail of a single email, including body content and attachment list.",
    request: `GET /api/fetch/123`,
    response: `{
  "content": "<p>Email body HTML</p>",
  "attachments": [
    { "id": "abc123def456", "filename": "invoice.pdf" }
  ]
}`,
  },
  {
    method: "GET",
    path: "/api/fetch/latest?to={address}&id={lastId}",
    description:
      "Long-poll for the next email newer than `id` (up to 1 minute). Returns 204 No Content on timeout with no new mail.",
    request: `GET /api/fetch/latest?to=foo@example.com&id=123`,
    response: `{
  "id": 124,
  "to": "foo@example.com",
  "from": "sender@example.org",
  "subject": "New message",
  "created_at": "2026-07-13T10:05:00Z"
}

// or, if no new mail arrives within 1 minute:
HTTP/1.1 204 No Content`,
  },
  {
    method: "GET",
    path: "/api/download/{id}",
    description: "Download an attachment by its ID. Returns the raw file with its original filename.",
    request: `GET /api/download/abc123def456`,
    response: `HTTP/1.1 200 OK
Content-Disposition: attachment; filename="invoice.pdf"

<binary file content>`,
  },
]

const errorExample = `{
  "message": "not found to address"
}`
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>API Docs - Tmail</title>
  </head>
  <body class="bg-background text-foreground min-h-screen">
    <div class="mx-auto max-w-3xl px-4 py-10 sm:px-6">
      <a href="/" class="text-muted-foreground text-sm hover:underline">&larr; Back to app</a>
      <h1 class="mt-3 text-2xl font-semibold sm:text-3xl">Tmail API</h1>
      <p class="text-muted-foreground mt-2 text-sm sm:text-base">
        No authentication required — access is controlled solely by knowing the mailbox address.
        All responses are JSON unless noted otherwise.
      </p>

      <div class="mt-8 space-y-8">
        {endpoints.map((ep) => (
          <section class="rounded-lg border p-4 sm:p-5">
            <div class="flex flex-wrap items-center gap-2">
              <span class="rounded-sm bg-primary px-2 py-0.5 text-xs font-semibold text-primary-foreground">
                {ep.method}
              </span>
              <code class="font-mono text-sm break-all sm:text-base">{ep.path}</code>
            </div>
            <p class="text-muted-foreground mt-2 text-sm">{ep.description}</p>

            {ep.request && (
              <div class="mt-3">
                <div class="text-muted-foreground mb-1 text-xs font-medium tracking-wide uppercase">
                  Example request
                </div>
                <pre class="bg-secondary overflow-x-auto rounded-md p-3 text-xs sm:text-sm"><code>{ep.request}</code></pre>
              </div>
            )}

            <div class="mt-3">
              <div class="text-muted-foreground mb-1 text-xs font-medium tracking-wide uppercase">
                Example response
              </div>
              <pre class="bg-secondary overflow-x-auto rounded-md p-3 text-xs sm:text-sm"><code>{ep.response}</code></pre>
            </div>
          </section>
        ))}

        <section class="rounded-lg border p-4 sm:p-5">
          <div class="text-sm font-semibold">Errors</div>
          <p class="text-muted-foreground mt-2 text-sm">
            Client errors return a 4xx status with a JSON body:
          </p>
          <pre class="bg-secondary mt-3 overflow-x-auto rounded-md p-3 text-xs sm:text-sm"><code>{errorExample}</code></pre>
        </section>
      </div>
    </div>
  </body>
</html>
